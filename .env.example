# ─────────────────────────────────────────
# Mailbook Backend — 환경변수 템플릿
# ─────────────────────────────────────────
# 사용법: 이 파일을 `.env` 로 복사 후 실제 값을 채워 사용하세요.
# 비밀(secret)이 포함된 항목은 절대 커밋하지 마세요.

# ─────────────────────────────────────────
# 환경 (local | production)
# ─────────────────────────────────────────
ENV=local
DEBUG=false

# ─────────────────────────────────────────
# PostgreSQL (필수)
# ─────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mailbook_backend

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# ─────────────────────────────────────────
# 인증 (JWT)
# ─────────────────────────────────────────
# 32자 이상 임의 문자열. `openssl rand -hex 32` 권장
JWT_SECRET_KEY=change-this-to-a-secure-random-secret
JWT_ALGORITHM=HS256
SESSION_TTL_SECONDS=86400

# ─────────────────────────────────────────
# CORS / 프론트엔드 연결
# ─────────────────────────────────────────
CORS_ALLOWED_FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────
# 로깅
# ─────────────────────────────────────────
LOG_LEVEL=INFO
