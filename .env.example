# ─────────────────────────────────────────
# Mailbook Backend — 환경변수 템플릿
# ─────────────────────────────────────────
# 사용법: 이 파일을 `.env` 로 복사 후 실제 값을 채워 사용하세요.
# 비밀(secret)이 포함된 항목은 절대 커밋하지 마세요.

# ─────────────────────────────────────────
# 환경 (local | production)
# ─────────────────────────────────────────
ENV=local
DEBUG=false

# ─────────────────────────────────────────
# PostgreSQL (필수)
# ─────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mailbook_backend

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# ─────────────────────────────────────────
# 인증 (JWT)
# ─────────────────────────────────────────
# 32자 이상 임의 문자열. `openssl rand -hex 32` 권장
JWT_SECRET_KEY=change-this-to-a-secure-random-secret
JWT_ALGORITHM=HS256
SESSION_TTL_SECONDS=86400

# ─────────────────────────────────────────
# CORS / 프론트엔드 연결
# ─────────────────────────────────────────
# 로컬 개발용
CORS_ALLOWED_FRONTEND_URL=http://localhost:3000
# Tailscale 운영용 (PWA): same-origin 이라 사실상 미사용이지만 일관성 위해 갱신
# CORS_ALLOWED_FRONTEND_URL=https://<hostname>.tail-XXXXX.ts.net

# ─────────────────────────────────────────
# 로깅
# ─────────────────────────────────────────
LOG_LEVEL=INFO

# ─────────────────────────────────────────
# 애플리케이션
# ─────────────────────────────────────────
TIMEZONE=Asia/Seoul
OWNER_USER_ID=1

# ─────────────────────────────────────────
# Anthropic (LLM 폴백 파서 + 매칭 disambiguation)
# ─────────────────────────────────────────
ANTHROPIC_API_KEY=
LLM_PARSER_MODEL=claude-haiku-4-5-20251001
LLM_DISAMBIGUATOR_MODEL=claude-haiku-4-5-20251001
LLM_CACHE_TTL_SECONDS=86400

# ─────────────────────────────────────────
# Gmail OAuth (Google Cloud Console에서 발급)
# ─────────────────────────────────────────
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
# 로컬 개발용
GMAIL_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/gmail/callback
# Tailscale 운영용 (PWA): Google Cloud Console 에 같은 URL 추가 등록 필요
# GMAIL_OAUTH_REDIRECT_URI=https://<hostname>.tail-XXXXX.ts.net/api/v1/auth/gmail/callback

# ─────────────────────────────────────────
# OAuth 토큰 암호화 (Fernet 키)
# 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ─────────────────────────────────────────
TOKEN_ENCRYPTION_KEY=

# ─────────────────────────────────────────
# Sync 동시 실행 차단 (Redis lock)
# ─────────────────────────────────────────
SYNC_LOCK_TTL_SECONDS=600
